# Copy to ".env.local". Next.js loads it automatically.
# Mirror the same URL + service_role secret in the assignment root ".env"
# (SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY) for Python import/scoring.

# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste_service_role_secret_here

# --- Optional: production “Run Scoring” / Vercel cron → GitHub Actions ---
# GITHUB_TRIGGER_TOKEN=
# GITHUB_REPO=owner/repo
# GITHUB_WORKFLOW_FILE=fraud-scoring.yml
# GITHUB_BRANCH=main
# CRON_SECRET=
